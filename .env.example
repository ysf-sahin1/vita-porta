# LLM provider — anthropic | openai | local
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_FRAMES=vitaporta/frames

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# RAG
CHROMA_PERSIST_DIR=./.chroma
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Agent confidence thresholds
GAIT_CONFIDENCE_THRESHOLD=0.5
SKIN_CONFIDENCE_THRESHOLD=0.5
RESPIRATION_CONFIDENCE_THRESHOLD=0.5

# ── Raspberry Pi gömülü sistem ayarları ──────────────────────────────────────
# PIR sensörü GPIO pin numarası (BCM numaralandırması, ör. 17 = fiziksel pin 11)
# Boş bırakılırsa PIR devre dışı, gateway sürekli çalışır.
PIR_PIN=17

# ESP32-CAM IP adresi (Pi hotspot üzerinde genellikle 192.168.4.2 olur)
ESP_HOST=192.168.4.2

# Pi WiFi Hotspot kimlik bilgileri — pi_setup.sh tarafından kullanılır
# ESP32 firmware'indeki WIFI_NETWORKS ile eşleşmeli!
HOTSPOT_SSID=vita-porta
HOTSPOT_PASS=vitaporta2026
