# LLM provider — anthropic | openai | local
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC_FRAMES=vitaporta/frames

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# RAG
CHROMA_PERSIST_DIR=./.chroma
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Agent confidence thresholds
GAIT_CONFIDENCE_THRESHOLD=0.5
SKIN_CONFIDENCE_THRESHOLD=0.5
RESPIRATION_CONFIDENCE_THRESHOLD=0.5
